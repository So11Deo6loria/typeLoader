{
  "enums": {},
  "structs": {
    "GPIO_Type": {
      "description": "TM4C/Tiva GPIO port register block (APB/AHB aperture). GPIODATA is bit-masked aliased across 0x000-0x3FC.",
      "struct": {
        "DATA_BITS": {"type": "uint32_t[256]", "comment": "0x000: GPIODATA bit-masked address aliases; bits [9:2] of address mask which pins are read/written"},
        "DIR": {"type": "uint32_t", "comment": "0x400: GPIO Direction (1=output)"},
        "IS": {"type": "uint32_t", "comment": "0x404: GPIO Interrupt Sense (1=level)"},
        "IBE": {"type": "uint32_t", "comment": "0x408: GPIO Interrupt Both Edges"},
        "IEV": {"type": "uint32_t", "comment": "0x40C: GPIO Interrupt Event (1=rising/high)"},
        "IM": {"type": "uint32_t", "comment": "0x410: GPIO Interrupt Mask"},
        "RIS": {"type": "uint32_t", "comment": "0x414: GPIO Raw Interrupt Status"},
        "MIS": {"type": "uint32_t", "comment": "0x418: GPIO Masked Interrupt Status"},
        "ICR": {"type": "uint32_t", "comment": "0x41C: GPIO Interrupt Clear"},
        "AFSEL": {"type": "uint32_t", "comment": "0x420: GPIO Alternate Function Select"},
        "RESERVED0": {"type": "uint32_t[55]", "comment": "0x424-0x4FF reserved"},
        "DR2R": {"type": "uint32_t", "comment": "0x500: GPIO 2-mA Drive Select"},
        "DR4R": {"type": "uint32_t", "comment": "0x504: GPIO 4-mA Drive Select"},
        "DR8R": {"type": "uint32_t", "comment": "0x508: GPIO 8-mA Drive Select"},
        "ODR": {"type": "uint32_t", "comment": "0x50C: GPIO Open Drain Select"},
        "PUR": {"type": "uint32_t", "comment": "0x510: GPIO Pull-Up Select"},
        "PDR": {"type": "uint32_t", "comment": "0x514: GPIO Pull-Down Select"},
        "SLR": {"type": "uint32_t", "comment": "0x518: GPIO Slew Rate Control Select"},
        "DEN": {"type": "uint32_t", "comment": "0x51C: GPIO Digital Enable"},
        "LOCK": {"type": "uint32_t", "comment": "0x520: GPIO Lock (write 0x4C4F434B to unlock CR)"},
        "CR": {"type": "uint32_t", "comment": "0x524: GPIO Commit"},
        "AMSEL": {"type": "uint32_t", "comment": "0x528: GPIO Analog Mode Select"},
        "PCTL": {"type": "uint32_t", "comment": "0x52C: GPIO Port Control (4-bit mux per pin)"},
        "ADCCTL": {"type": "uint32_t", "comment": "0x530: GPIO ADC Control"},
        "DMACTL": {"type": "uint32_t", "comment": "0x534: GPIO DMA Control"}
      }
    },
    "UART_Type": {
      "description": "TM4C/Tiva UART register block (ARM PL011 derived).",
      "struct": {
        "DR": {"type": "uint32_t", "comment": "0x000: UART Data"},
        "RSR_ECR": {"type": "uint32_t", "comment": "0x004: UART Receive Status / Error Clear"},
        "RESERVED0": {"type": "uint32_t[4]", "comment": "0x008-0x017 reserved"},
        "FR": {"type": "uint32_t", "comment": "0x018: UART Flag (TXFE/RXFF/TXFF/RXFE/BUSY/CTS)"},
        "RESERVED1": {"type": "uint32_t", "comment": "0x01C reserved"},
        "ILPR": {"type": "uint32_t", "comment": "0x020: UART IrDA Low-Power Register"},
        "IBRD": {"type": "uint32_t", "comment": "0x024: UART Integer Baud-Rate Divisor"},
        "FBRD": {"type": "uint32_t", "comment": "0x028: UART Fractional Baud-Rate Divisor"},
        "LCRH": {"type": "uint32_t", "comment": "0x02C: UART Line Control"},
        "CTL": {"type": "uint32_t", "comment": "0x030: UART Control (UARTEN/TXE/RXE)"},
        "IFLS": {"type": "uint32_t", "comment": "0x034: UART Interrupt FIFO Level Select"},
        "IM": {"type": "uint32_t", "comment": "0x038: UART Interrupt Mask"},
        "RIS": {"type": "uint32_t", "comment": "0x03C: UART Raw Interrupt Status"},
        "MIS": {"type": "uint32_t", "comment": "0x040: UART Masked Interrupt Status"},
        "ICR": {"type": "uint32_t", "comment": "0x044: UART Interrupt Clear"},
        "DMACTL": {"type": "uint32_t", "comment": "0x048: UART DMA Control"},
        "RESERVED2": {"type": "uint32_t[22]", "comment": "0x04C-0x0A3 reserved"},
        "9BITADDR": {"type": "uint32_t", "comment": "0x0A4: UART 9-Bit Self Address"},
        "9BITAMASK": {"type": "uint32_t", "comment": "0x0A8: UART 9-Bit Self Address Mask"},
        "RESERVED3": {"type": "uint32_t[965]", "comment": "0x0AC-0xFBF reserved"},
        "PP": {"type": "uint32_t", "comment": "0xFC0: UART Peripheral Properties"},
        "RESERVED4": {"type": "uint32_t", "comment": "0xFC4 reserved"},
        "CC": {"type": "uint32_t", "comment": "0xFC8: UART Clock Configuration"}
      }
    },
    "SSI_Type": {
      "description": "TM4C/Tiva SSI (SPI) register block (ARM PL022 derived).",
      "struct": {
        "CR0": {"type": "uint32_t", "comment": "0x000: SSI Control 0 (DSS/FRF/SPO/SPH/SCR)"},
        "CR1": {"type": "uint32_t", "comment": "0x004: SSI Control 1 (LBM/SSE/MS/SOD)"},
        "DR": {"type": "uint32_t", "comment": "0x008: SSI Data"},
        "SR": {"type": "uint32_t", "comment": "0x00C: SSI Status (TFE/TNF/RNE/RFF/BSY)"},
        "CPSR": {"type": "uint32_t", "comment": "0x010: SSI Clock Prescale"},
        "IM": {"type": "uint32_t", "comment": "0x014: SSI Interrupt Mask"},
        "RIS": {"type": "uint32_t", "comment": "0x018: SSI Raw Interrupt Status"},
        "MIS": {"type": "uint32_t", "comment": "0x01C: SSI Masked Interrupt Status"},
        "ICR": {"type": "uint32_t", "comment": "0x020: SSI Interrupt Clear"},
        "DMACTL": {"type": "uint32_t", "comment": "0x024: SSI DMA Control"},
        "RESERVED0": {"type": "uint32_t[1000]", "comment": "0x028-0xFC7 reserved"},
        "CC": {"type": "uint32_t", "comment": "0xFC8: SSI Clock Configuration"}
      }
    },
    "I2C_Type": {
      "description": "TM4C/Tiva I2C master register block (master aperture starting at 0x000).",
      "struct": {
        "MSA": {"type": "uint32_t", "comment": "0x000: I2C Master Slave Address (address + R/S bit)"},
        "MCS": {"type": "uint32_t", "comment": "0x004: I2C Master Control/Status"},
        "MDR": {"type": "uint32_t", "comment": "0x008: I2C Master Data"},
        "MTPR": {"type": "uint32_t", "comment": "0x00C: I2C Master Timer Period"},
        "MIMR": {"type": "uint32_t", "comment": "0x010: I2C Master Interrupt Mask"},
        "MRIS": {"type": "uint32_t", "comment": "0x014: I2C Master Raw Interrupt Status"},
        "MMIS": {"type": "uint32_t", "comment": "0x018: I2C Master Masked Interrupt Status"},
        "MICR": {"type": "uint32_t", "comment": "0x01C: I2C Master Interrupt Clear"},
        "MCR": {"type": "uint32_t", "comment": "0x020: I2C Master Configuration"},
        "MCLKOCNT": {"type": "uint32_t", "comment": "0x024: I2C Master Clock Low Timeout Count"},
        "RESERVED0": {"type": "uint32_t", "comment": "0x028 reserved"},
        "MBMON": {"type": "uint32_t", "comment": "0x02C: I2C Master Bus Monitor (SCL/SDA state)"},
        "RESERVED1": {"type": "uint32_t[2]", "comment": "0x030-0x037 reserved"},
        "MCR2": {"type": "uint32_t", "comment": "0x038: I2C Master Configuration 2 (glitch filter)"}
      }
    },
    "TIMER_Type": {
      "description": "TM4C/Tiva General-Purpose Timer Module (GPTM) register block.",
      "struct": {
        "CFG": {"type": "uint32_t", "comment": "0x000: GPTM Configuration"},
        "TAMR": {"type": "uint32_t", "comment": "0x004: GPTM Timer A Mode"},
        "TBMR": {"type": "uint32_t", "comment": "0x008: GPTM Timer B Mode"},
        "CTL": {"type": "uint32_t", "comment": "0x00C: GPTM Control (TAEN/TBEN)"},
        "SYNC": {"type": "uint32_t", "comment": "0x010: GPTM Synchronize"},
        "RESERVED0": {"type": "uint32_t", "comment": "0x014 reserved"},
        "IMR": {"type": "uint32_t", "comment": "0x018: GPTM Interrupt Mask"},
        "RIS": {"type": "uint32_t", "comment": "0x01C: GPTM Raw Interrupt Status"},
        "MIS": {"type": "uint32_t", "comment": "0x020: GPTM Masked Interrupt Status"},
        "ICR": {"type": "uint32_t", "comment": "0x024: GPTM Interrupt Clear"},
        "TAILR": {"type": "uint32_t", "comment": "0x028: GPTM Timer A Interval Load"},
        "TBILR": {"type": "uint32_t", "comment": "0x02C: GPTM Timer B Interval Load"},
        "TAMATCHR": {"type": "uint32_t", "comment": "0x030: GPTM Timer A Match"},
        "TBMATCHR": {"type": "uint32_t", "comment": "0x034: GPTM Timer B Match"},
        "TAPR": {"type": "uint32_t", "comment": "0x038: GPTM Timer A Prescale"},
        "TBPR": {"type": "uint32_t", "comment": "0x03C: GPTM Timer B Prescale"},
        "TAPMR": {"type": "uint32_t", "comment": "0x040: GPTM Timer A Prescale Match"},
        "TBPMR": {"type": "uint32_t", "comment": "0x044: GPTM Timer B Prescale Match"},
        "TAR": {"type": "uint32_t", "comment": "0x048: GPTM Timer A (current value)"},
        "TBR": {"type": "uint32_t", "comment": "0x04C: GPTM Timer B (current value)"},
        "TAV": {"type": "uint32_t", "comment": "0x050: GPTM Timer A Value"},
        "TBV": {"type": "uint32_t", "comment": "0x054: GPTM Timer B Value"},
        "RTCPD": {"type": "uint32_t", "comment": "0x058: GPTM RTC Predivide"},
        "TAPS": {"type": "uint32_t", "comment": "0x05C: GPTM Timer A Prescale Snapshot"},
        "TBPS": {"type": "uint32_t", "comment": "0x060: GPTM Timer B Prescale Snapshot"},
        "TAPV": {"type": "uint32_t", "comment": "0x064: GPTM Timer A Prescale Value"},
        "TBPV": {"type": "uint32_t", "comment": "0x068: GPTM Timer B Prescale Value"},
        "RESERVED1": {"type": "uint32_t[981]", "comment": "0x06C-0xFBF reserved"},
        "PP": {"type": "uint32_t", "comment": "0xFC0: GPTM Peripheral Properties"}
      }
    },
    "ADC_Type": {
      "description": "TM4C/Tiva ADC register block (sequencer-based; partial coverage of common control registers).",
      "struct": {
        "ACTSS": {"type": "uint32_t", "comment": "0x000: ADC Active Sample Sequencer (ASEN0-3)"},
        "RIS": {"type": "uint32_t", "comment": "0x004: ADC Raw Interrupt Status"},
        "IM": {"type": "uint32_t", "comment": "0x008: ADC Interrupt Mask"},
        "ISC": {"type": "uint32_t", "comment": "0x00C: ADC Interrupt Status and Clear"},
        "OSTAT": {"type": "uint32_t", "comment": "0x010: ADC Overflow Status"},
        "EMUX": {"type": "uint32_t", "comment": "0x014: ADC Event Multiplexer Select (trigger source per SS)"},
        "USTAT": {"type": "uint32_t", "comment": "0x018: ADC Underflow Status"},
        "TSSEL": {"type": "uint32_t", "comment": "0x01C: ADC Trigger Source Select"},
        "SSPRI": {"type": "uint32_t", "comment": "0x020: ADC Sample Sequencer Priority"},
        "SPC": {"type": "uint32_t", "comment": "0x024: ADC Sample Phase Control"},
        "PSSI": {"type": "uint32_t", "comment": "0x028: ADC Processor Sample Sequence Initiate"},
        "RESERVED0": {"type": "uint32_t", "comment": "0x02C reserved"},
        "SAC": {"type": "uint32_t", "comment": "0x030: ADC Sample Averaging Control"},
        "DCISC": {"type": "uint32_t", "comment": "0x034: ADC Digital Comparator Interrupt Status and Clear"},
        "CTL": {"type": "uint32_t", "comment": "0x038: ADC Control"}
      }
    },
    "SYSCTL_Type": {
      "description": "TM4C123 System Control partial focused on device ID, clock config, and run-mode clock gating (RCGCx). Offsets are relative to the System Control base 0x400FE000. Reserved padding preserves absolute offsets; only fields below are confidently placed.",
      "struct": {
        "DID0": {"type": "uint32_t", "comment": "0x000: Device Identification 0"},
        "DID1": {"type": "uint32_t", "comment": "0x004: Device Identification 1"},
        "RESERVED0": {"type": "uint32_t[10]", "comment": "0x008-0x02F reserved (legacy DCn region)"},
        "PBORCTL": {"type": "uint32_t", "comment": "0x030: Brown-Out Reset Control"},
        "RESERVED1": {"type": "uint32_t[11]", "comment": "0x034-0x05F reserved (legacy RIS/IMC/MISC/RESC region)"},
        "RCC": {"type": "uint32_t", "comment": "0x060: Run-Mode Clock Configuration"},
        "RESERVED2": {"type": "uint32_t[2]", "comment": "0x064-0x06B reserved"},
        "GPIOHBCTL": {"type": "uint32_t", "comment": "0x06C: GPIO High-Performance Bus Control (AHB aperture select)"},
        "RCC2": {"type": "uint32_t", "comment": "0x070: Run-Mode Clock Configuration 2"},
        "RESERVED3": {"type": "uint32_t[2]", "comment": "0x074-0x07B reserved"},
        "MOSCCTL": {"type": "uint32_t", "comment": "0x07C: Main Oscillator Control"},
        "RESERVED4": {"type": "uint32_t[352]", "comment": "0x080-0x5FF reserved (legacy DC/SRCR/RCGC0-2/SCGC/DCGC region)"},
        "RCGCWD": {"type": "uint32_t", "comment": "0x600: Watchdog Timer Run Mode Clock Gating Control"},
        "RCGCTIMER": {"type": "uint32_t", "comment": "0x604: 16/32-bit Timer Run Mode Clock Gating Control"},
        "RCGCGPIO": {"type": "uint32_t", "comment": "0x608: GPIO Run Mode Clock Gating Control (bit n = port n)"},
        "RCGCDMA": {"type": "uint32_t", "comment": "0x60C: uDMA Run Mode Clock Gating Control"},
        "RESERVED5": {"type": "uint32_t", "comment": "0x610 reserved"},
        "RCGCHIB": {"type": "uint32_t", "comment": "0x614: Hibernation Run Mode Clock Gating Control"},
        "RCGCUART": {"type": "uint32_t", "comment": "0x618: UART Run Mode Clock Gating Control (bit n = UARTn)"},
        "RCGCSSI": {"type": "uint32_t", "comment": "0x61C: SSI Run Mode Clock Gating Control (bit n = SSIn)"},
        "RCGCI2C": {"type": "uint32_t", "comment": "0x620: I2C Run Mode Clock Gating Control (bit n = I2Cn)"},
        "RESERVED6": {"type": "uint32_t", "comment": "0x624 reserved"},
        "RCGCUSB": {"type": "uint32_t", "comment": "0x628: USB Run Mode Clock Gating Control"},
        "RESERVED7": {"type": "uint32_t[2]", "comment": "0x62C-0x633 reserved"},
        "RCGCCAN": {"type": "uint32_t", "comment": "0x634: CAN Run Mode Clock Gating Control"},
        "RCGCADC": {"type": "uint32_t", "comment": "0x638: ADC Run Mode Clock Gating Control"},
        "RCGCACMP": {"type": "uint32_t", "comment": "0x63C: Analog Comparator Run Mode Clock Gating Control"},
        "RCGCPWM": {"type": "uint32_t", "comment": "0x640: PWM Run Mode Clock Gating Control"},
        "RCGCQEI": {"type": "uint32_t", "comment": "0x644: QEI Run Mode Clock Gating Control"},
        "RESERVED8": {"type": "uint32_t[4]", "comment": "0x648-0x657 reserved"},
        "RCGCEEPROM": {"type": "uint32_t", "comment": "0x658: EEPROM Run Mode Clock Gating Control"},
        "RCGCWTIMER": {"type": "uint32_t", "comment": "0x65C: Wide Timer Run Mode Clock Gating Control"}
      }
    },
    "PWM_Type": {
      "description": "TM4C/Tiva PWM module top-level register block (partial: control/sync and per-generator block follows). Per-generator sub-blocks begin at 0x040.",
      "struct": {
        "CTL": {"type": "uint32_t", "comment": "0x000: PWM Master Control"},
        "SYNC": {"type": "uint32_t", "comment": "0x004: PWM Time Base Sync"},
        "ENABLE": {"type": "uint32_t", "comment": "0x008: PWM Output Enable"},
        "INVERT": {"type": "uint32_t", "comment": "0x00C: PWM Output Inversion"},
        "FAULT": {"type": "uint32_t", "comment": "0x010: PWM Output Fault"},
        "INTEN": {"type": "uint32_t", "comment": "0x014: PWM Interrupt Enable"},
        "RIS": {"type": "uint32_t", "comment": "0x018: PWM Raw Interrupt Status"},
        "ISC": {"type": "uint32_t", "comment": "0x01C: PWM Interrupt Status and Clear"},
        "STATUS": {"type": "uint32_t", "comment": "0x020: PWM Status"},
        "FAULTVAL": {"type": "uint32_t", "comment": "0x024: PWM Fault Condition Value"},
        "ENUPD": {"type": "uint32_t", "comment": "0x028: PWM Enable Update"}
      }
    },
    "uDMA_ControlTable_Entry": {
      "description": "TM4C/Tiva uDMA channel control structure entry (alpha then beta = 16 bytes per channel; table is 32 or 64 of these). Matches tDMAControlTable / udma_control_table layout.",
      "struct": {
        "SRCENDP": {"type": "void *", "comment": "Source end pointer (address of last source element)"},
        "DSTENDP": {"type": "void *", "comment": "Destination end pointer (address of last destination element)"},
        "CHCTL": {"type": "uint32_t", "comment": "Channel control word (XFERMODE/XFERSIZE/ARBSIZE/SRCSIZE/DSTSIZE/SRCINC/DSTINC)"},
        "UNUSED": {"type": "uint32_t", "comment": "Reserved/unused word (pads entry to 16 bytes)"}
      }
    }
  }
}
