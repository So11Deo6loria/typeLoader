        "baud_rate": {"type": "int", "comment": "UART baud rate"},
        "data_bits": {"type": "int", "comment": "uart_word_length_t: number of data bits"},
        "parity": {"type": "int", "comment": "uart_parity_t: parity mode"},
        "stop_bits": {"type": "int", "comment": "uart_stop_bits_t: number of stop bits"},
        "flow_ctrl": {"type": "int", "comment": "uart_hw_flowcontrol_t: HW flow control mode"},
        "rx_flow_ctrl_thresh": {"type": "uint8_t", "comment": "RX flow control RTS threshold (when flow_ctrl uses RTS)"},
        "source_clk": {"type": "int", "comment": "uart_sclk_t: UART source clock selection (union with use_ref_tick on older IDF)"}
      }
    },
    "gpio_config_t": {
      "description": "ESP-IDF GPIO driver configuration struct (driver/gpio.h). pin_bit_mask is uint64_t in IDF; modeled as uint32_t[2] (low word = GPIO0-31, high word = GPIO32-39).",
      "struct": {
        "pin_bit_mask": {"type": "uint32_t[2]", "comment": "GPIO pin bitmask (uint64_t in IDF: [0]=GPIO0-31, [1]=GPIO32-39)"},
        "mode": {"type": "int", "comment": "gpio_mode_t: GPIO mode (input/output/etc.)"},
        "pull_up_en": {"type": "int", "comment": "gpio_pullup_t: enable internal pull-up"},
        "pull_down_en": {"type": "int", "comment": "gpio_pulldown_t: enable internal pull-down"},
        "intr_type": {"type": "int", "comment": "gpio_int_type_t: interrupt trigger type"}
      }
    },
    "spi_bus_config_t": {
      "description": "ESP-IDF SPI master/common bus configuration struct (driver/spi_common.h). Head fields confirmed; data*_io_num are unions with quad pins. Field order matches ESP-IDF.",
      "struct": {
        "mosi_io_num": {"type": "int", "comment": "GPIO for MOSI (data0), -1 if unused (union: data0_io_num)"},
        "miso_io_num": {"type": "int", "comment": "GPIO for MISO (data1), -1 if unused (union: data1_io_num)"},
        "sclk_io_num": {"type": "int", "comment": "GPIO for SPI clock, -1 if unused"},
        "quadwp_io_num": {"type": "int", "comment": "GPIO for WP (write protect, data2), -1 if unused (union: data2_io_num)"},
        "quadhd_io_num": {"type": "int", "comment": "GPIO for HD (hold, data3), -1 if unused (union: data3_io_num)"},
        "max_transfer_sz": {"type": "int", "comment": "Maximum transfer size in bytes (0 = default 4092)"},
        "flags": {"type": "uint32_t", "comment": "Abilities of bus to be checked by driver (SPICOMMON_BUSFLAG_*)"},
        "intr_flags": {"type": "int", "comment": "Interrupt flag for the bus to set the priority and IRAM attribute"}
      }
    }
  }
}
