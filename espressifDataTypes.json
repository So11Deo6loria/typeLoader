        "mem_rx_status": {"type": "uint32_t", "comment": "0x64 RX FIFO write/read offset status"},
        "mem_cnt_status": {"type": "uint32_t", "comment": "0x68 RX/TX FIFO count status"},
        "pospulse": {"type": "uint32_t", "comment": "0x6c Autobaud positive pulse min count"},
        "negpulse": {"type": "uint32_t", "comment": "0x70 Autobaud negative pulse min count"},
        "reserved_74": {"type": "uint32_t", "comment": "0x74 reserved"},
        "reserved_78": {"type": "uint32_t", "comment": "0x78 reserved"},
        "date": {"type": "uint32_t", "comment": "0x7c Version/date register"},
        "id": {"type": "uint32_t", "comment": "0x80 Peripheral ID register"}
      }
    },
    "spi_dev_t": {
      "description": "ESP32 SPI peripheral register block (SPI2/HSPI base 0x3FF64000, SPI3/VSPI 0x3FF65000). Each 32-bit register modeled as one uint32_t in offset order. CONFIRMED head through data_buf[16]; tail registers omitted.",
      "struct": {
        "cmd": {"type": "uint32_t", "comment": "0x00 Command register (USR start bit)"},
        "addr": {"type": "uint32_t", "comment": "0x04 Address to send"},
        "ctrl": {"type": "uint32_t", "comment": "0x08 Control (bit order, dummy, dual/quad)"},
        "ctrl1": {"type": "uint32_t", "comment": "0x0c Control 1 (CS setup/hold timing)"},
        "ctrl2": {"type": "uint32_t", "comment": "0x10 Control 2 (clock edge/delay timing)"},
        "clock": {"type": "uint32_t", "comment": "0x14 Clock config (prescaler, divider)"},
        "user": {"type": "uint32_t", "comment": "0x18 User-defined transaction phases"},
        "user1": {"type": "uint32_t", "comment": "0x1c User config 1 (addr/dummy bit lengths)"},
        "user2": {"type": "uint32_t", "comment": "0x20 User config 2 (command value/length)"},
        "mosi_dlen": {"type": "uint32_t", "comment": "0x24 MOSI data bit length"},
        "miso_dlen": {"type": "uint32_t", "comment": "0x28 MISO data bit length"},
        "slv_wr_status": {"type": "uint32_t", "comment": "0x2c Slave write status / dummy"},
        "pin": {"type": "uint32_t", "comment": "0x30 CS pin and clock idle config"},
        "slave": {"type": "uint32_t", "comment": "0x34 Slave mode config and interrupt enable"},
        "slave1": {"type": "uint32_t", "comment": "0x38 Slave config 1 (buffer bit lengths)"},
        "slave2": {"type": "uint32_t", "comment": "0x3c Slave config 2 (dummy cycles)"},
        "slave3": {"type": "uint32_t", "comment": "0x40 Slave config 3 (command values)"},
        "slv_wrbuf_dlen": {"type": "uint32_t", "comment": "0x44 Slave write-buffer data bit length"},
        "slv_rdbuf_dlen": {"type": "uint32_t", "comment": "0x48 Slave read-buffer data bit length"},
        "cache_fctrl": {"type": "uint32_t", "comment": "0x4c Cache flash control"},
        "cache_sctrl": {"type": "uint32_t", "comment": "0x50 Cache SRAM control"},
        "sram_cmd": {"type": "uint32_t", "comment": "0x54 SRAM command"},
        "sram_drd_cmd": {"type": "uint32_t", "comment": "0x58 SRAM read command"},
        "sram_dwr_cmd": {"type": "uint32_t", "comment": "0x5c SRAM write command"},
        "slv_rd_bit": {"type": "uint32_t", "comment": "0x60 Slave read data bit count"},
