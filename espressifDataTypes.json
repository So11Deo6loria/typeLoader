        "status": {"type": "uint32_t", "comment": "0x1c Status (RX/TX FIFO counts, line levels)"},
        "conf0": {"type": "uint32_t", "comment": "0x20 Config 0 (parity, bit num, stop bits)"},
        "conf1": {"type": "uint32_t", "comment": "0x24 Config 1 (FIFO thresholds)"},
        "lowpulse": {"type": "uint32_t", "comment": "0x28 Autobaud minimum low pulse"},
        "highpulse": {"type": "uint32_t", "comment": "0x2c Autobaud minimum high pulse"},
        "rxd_cnt": {"type": "uint32_t", "comment": "0x30 Autobaud edge count"},
