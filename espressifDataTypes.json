        "swfc_conf0": {"type": "uint32_t", "comment": "0x3c Software flow control XON/XOFF chars"},
        "swfc_conf1": {"type": "uint32_t", "comment": "0x40 Software flow control thresholds"},
        "idle_conf": {"type": "uint32_t", "comment": "0x44 Frame end idle time"},
        "rs485_conf": {"type": "uint32_t", "comment": "0x48 RS485 mode config"},
        "at_cmd_precnt": {"type": "uint32_t", "comment": "0x4c AT escape sequence pre-idle"},
        "at_cmd_postcnt": {"type": "uint32_t", "comment": "0x50 AT escape sequence post-idle"},
        "at_cmd_gaptout": {"type": "uint32_t", "comment": "0x54 AT escape sequence gap timeout"},
        "at_cmd_char": {"type": "uint32_t", "comment": "0x58 AT escape sequence char config"},
        "mem_conf": {"type": "uint32_t", "comment": "0x5c FIFO memory config"},
