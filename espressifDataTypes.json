  "structs": {
    "gpio_dev_t": {
      "description": "ESP32 GPIO peripheral register block (GPIO base 0x3FF44000, &GPIO). Each 32-bit register modeled as one uint32_t in offset order; bitfield unions in ESP-IDF flattened. PARTIAL/CONFIRMED through pin[40]; tail func_in/out sel arrays included with confident offsets.",
      "struct": {
        "bt_select": {"type": "uint32_t", "comment": "0x00 GPIO bit select for BT"},
        "out": {"type": "uint32_t", "comment": "0x04 GPIO0-31 output value"},
        "out_w1ts": {"type": "uint32_t", "comment": "0x08 GPIO0-31 output set (write 1 to set)"},
        "out_w1tc": {"type": "uint32_t", "comment": "0x0c GPIO0-31 output clear (write 1 to clear)"},
        "out1": {"type": "uint32_t", "comment": "0x10 GPIO32-39 output value (low 8 bits)"},
        "out1_w1ts": {"type": "uint32_t", "comment": "0x14 GPIO32-39 output set"},
        "out1_w1tc": {"type": "uint32_t", "comment": "0x18 GPIO32-39 output clear"},
        "sdio_select": {"type": "uint32_t", "comment": "0x1c SDIO select (reserved on some variants)"},
        "enable": {"type": "uint32_t", "comment": "0x20 GPIO0-31 output enable"},
        "enable_w1ts": {"type": "uint32_t", "comment": "0x24 GPIO0-31 output enable set"},
        "enable_w1tc": {"type": "uint32_t", "comment": "0x28 GPIO0-31 output enable clear"},
        "enable1": {"type": "uint32_t", "comment": "0x2c GPIO32-39 output enable"},
        "enable1_w1ts": {"type": "uint32_t", "comment": "0x30 GPIO32-39 output enable set"},
        "enable1_w1tc": {"type": "uint32_t", "comment": "0x34 GPIO32-39 output enable clear"},
        "strap": {"type": "uint32_t", "comment": "0x38 Bootstrap pin values"},
        "in": {"type": "uint32_t", "comment": "0x3c GPIO0-31 input value"},
        "in1": {"type": "uint32_t", "comment": "0x40 GPIO32-39 input value"},
        "status": {"type": "uint32_t", "comment": "0x44 GPIO0-31 interrupt status"},
        "status_w1ts": {"type": "uint32_t", "comment": "0x48 interrupt status set"},
        "status_w1tc": {"type": "uint32_t", "comment": "0x4c interrupt status clear"},
        "status1": {"type": "uint32_t", "comment": "0x50 GPIO32-39 interrupt status"},
        "status1_w1ts": {"type": "uint32_t", "comment": "0x54 interrupt status set"},
        "status1_w1tc": {"type": "uint32_t", "comment": "0x58 interrupt status clear"},
        "reserved_5c": {"type": "uint32_t", "comment": "0x5c reserved"},
        "acpu_int": {"type": "uint32_t", "comment": "0x60 APP CPU interrupt status GPIO0-31"},
        "acpu_nmi_int": {"type": "uint32_t", "comment": "0x64 APP CPU NMI interrupt status GPIO0-31"},
        "pcpu_int": {"type": "uint32_t", "comment": "0x68 PRO CPU interrupt status GPIO0-31"},
        "pcpu_nmi_int": {"type": "uint32_t", "comment": "0x6c PRO CPU NMI interrupt status GPIO0-31"},
        "cpusdio_int": {"type": "uint32_t", "comment": "0x70 SDIO CPU interrupt status GPIO0-31"},
        "acpu_int1": {"type": "uint32_t", "comment": "0x74 APP CPU interrupt status GPIO32-39"},
        "acpu_nmi_int1": {"type": "uint32_t", "comment": "0x78 APP CPU NMI interrupt status GPIO32-39"},
        "pcpu_int1": {"type": "uint32_t", "comment": "0x7c PRO CPU interrupt status GPIO32-39"},
        "pcpu_nmi_int1": {"type": "uint32_t", "comment": "0x80 PRO CPU NMI interrupt status GPIO32-39"},
        "cpusdio_int1": {"type": "uint32_t", "comment": "0x84 SDIO CPU interrupt status GPIO32-39"},
        "pin": {"type": "uint32_t[40]", "comment": "0x88 Per-GPIO pin config registers (wakeup, int type, pad driver) for GPIO0-39"},
        "cali_conf": {"type": "uint32_t", "comment": "0x128 RTC calibration config"},
        "cali_data": {"type": "uint32_t", "comment": "0x12c RTC calibration data"},
        "func_in_sel_cfg": {"type": "uint32_t[256]", "comment": "0x130 GPIO input signal mux config (256 peripheral input signals)"},
        "func_out_sel_cfg": {"type": "uint32_t[40]", "comment": "0x530 GPIO output signal mux config (one per GPIO0-39)"}
      }
    },
    "uart_dev_t": {
      "description": "ESP32 UART peripheral register block (UART0 base 0x3FF40000). Each 32-bit register modeled as one uint32_t in offset order. CONFIRMED full ESP32 classic layout through id register.",
      "struct": {
        "fifo": {"type": "uint32_t", "comment": "0x00 FIFO data register (RW byte in low 8 bits)"},
        "int_raw": {"type": "uint32_t", "comment": "0x04 Raw interrupt status"},
        "int_st": {"type": "uint32_t", "comment": "0x08 Masked interrupt status"},
        "int_ena": {"type": "uint32_t", "comment": "0x0c Interrupt enable"},
        "int_clr": {"type": "uint32_t", "comment": "0x10 Interrupt clear"},
