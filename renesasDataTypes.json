                "p_extend": {"type": "void *", "comment": "Pointer to peripheral-specific extended configuration"}
            }
        },
        "spi_cfg_t": {
            "description": "FSP SPI interface configuration (spi_api.h). Pointer widths are 32-bit (Cortex-M). Field order matches the FSP struct.",
            "struct": {
