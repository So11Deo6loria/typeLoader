                "tei_irq": {"type": "int", "comment": "IRQ_t Transmit-end IRQ number"},
                "eri_irq": {"type": "int", "comment": "IRQ_t Receive-error IRQ number"},
                "rxi_ipl": {"type": "uint8_t", "comment": "Receive interrupt priority"},
                "txi_ipl": {"type": "uint8_t", "comment": "Transmit interrupt priority"},
